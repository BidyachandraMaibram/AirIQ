# ── AirIQ Environment Variables ──────────────────────────────────────────────
# Copy this file to .env and fill in your real values.
# Never commit .env to version control.

# ── External API keys ─────────────────────────────────────────────────────────
CPCB_API_KEY=
ANTHROPIC_API_KEY=

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Scheduler ─────────────────────────────────────────────────────────────────
SCHEDULER_INTERVAL_MINUTES=30

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
